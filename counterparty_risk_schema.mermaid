classDef purple fill:#CECBF6,stroke:#534AB7,color:#26215C;
classDef teal fill:#9FE1CB,stroke:#0F6E56,color:#04342C;
classDef coral fill:#F5C4B3,stroke:#993C1D,color:#4A1B0C;
classDef pink fill:#F4C0D1,stroke:#993556,color:#4B1528;
classDef gray fill:#D3D1C7,stroke:#5F5E5A,color:#2C2C2A;
class RA,RI,RR,AR,RT,J,CO,SD,DC purple;
class LE,CG,PF,NS,MA,CA,CP,CAS,LO,TR,PT,RF,CUR teal;
