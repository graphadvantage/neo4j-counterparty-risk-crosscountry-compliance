end
subgraph GRC["Compliance & governance"]
direction LR
OU["OrganizationalUnit"]
IP["InternalPolicy"]
CTL["Control"]
EV["EvidenceArtifact"]
CAM["ComplianceAssessment"]
GAP["ComplianceGap"]
end
subgraph PROV["Provenance"]
SYS["SourceSystem"]
end
